{
  "name": "dridock-ts",
  "description": "TypeScript rewrite of the dridock host-side wrapper (parallel to wrapper.sh during phased migration)",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "src/cli/main.ts",
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli/main.ts --compile --minify --sourcemap --outfile bin/dridock"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
