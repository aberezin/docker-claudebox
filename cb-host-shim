#!/usr/bin/env bash
# summary: (internal) proxy a host-only command (colima/limactl) to the Mac host agent
# cb-host-shim — baked onto the container PATH as `colima` and `limactl`. When a claudebot is
# developing THIS harness inside a container, the framework's `colima …`/`limactl …` calls land
# here and are proxied to the Mac's `dridock host-agent` (Approach 2, task #15). Off unless the
# human ran `dridock host-agent up` (opt-in, trusted dev only). See docs/design/backends.md.
set -uo pipefail

_cmd="$(basename "$0")"
url="${DRIDOCK_HOST_AGENT_URL:-${CLAUDEBOX_HOST_AGENT_URL:-}}"
tok="${DRIDOCK_HOST_AGENT_TOKEN:-${CLAUDEBOX_HOST_AGENT_TOKEN:-}}"
if [ -z "$url" ] || [ -z "$tok" ]; then
    echo "$_cmd: dridock host agent not available — this is a shim that proxies to the Mac." >&2
    echo "  Enable it on the Mac (opt-in, trusted harness-dev only):  dridock host-agent up" >&2
    echo "  then restart this session so the agent URL/token are injected." >&2
    exit 70
fi
host="${url%%:*}"; port="${url##*:}"

# argv as a JSON array: [<cmd>, <args…>]
argv_json="$(python3 -c 'import json,sys; print(json.dumps(sys.argv[1:]))' "$_cmd" "$@")" \
    || { echo "$_cmd: failed to encode args" >&2; exit 70; }

exec 3<>"/dev/tcp/$host/$port" || { echo "$_cmd: cannot reach host agent at $url (is it up?)" >&2; exit 70; }
printf '%s\n%s\n' "$tok" "$argv_json" >&3

_ec=1
while IFS= read -r _line <&3; do
    case "$_line" in
        __CBEXIT__\ *) _ec="${_line#__CBEXIT__ }" ;;
        *) printf '%s\n' "$_line" ;;
    esac
done
exec 3>&- 2>/dev/null || true
exit "$_ec"
