#!/usr/bin/env bash
# summary: file a bug report about the dridock FRAMEWORK (not your project) to the host
# cb-report-bug — file a report about a suspected bug in the CLAUDEBOX FRAMEWORK
# (the wrapper / entrypoint / image / networking that runs you), NOT a bug in the
# project you are building. Reports are written to a shared, host-visible drop dir
# mounted into every container, so the maintainer collects them across all projects
# with `dridock framework-bugs` on the Mac.
#
# The detailed body is read from --body-file or stdin (a heredoc is ideal). Use the
# template the baked CLAUDE.md describes: what you were doing, expected vs actual,
# minimal repro, and your hypothesis.
#
#   cb-report-bug "workspace empty under /tmp" --layer wrapper <<'EOF'
#   ## What I was doing
#   Bootstrapped a project under /tmp and started claudebot.
#   ## Expected vs actual
#   Expected the workspace files; got an empty directory.
#   ## Repro / hypothesis
#   macOS /tmp -> /private/tmp symlink; the bind-mount path didn't match the VM share.
#   EOF
set -euo pipefail

DIR="${CLAUDEBOX_FRAMEWORK_BUGS_DIR:-/home/claude/framework-bugs}"
PID="${CLAUDEBOX_PROJECT_ID:-unknown}"
LAYER="other"
TITLE=""
BODY_FILE=""

usage() {
    cat >&2 <<EOF
usage:
  cb-report-bug "<title>" [--layer wrapper|entrypoint|image|networking|other] [--body-file F]
                                file a framework-bug report (body on stdin or --body-file)
  cb-report-bug list            list every framework-bug in the shared drop dir (marks reviewed)
  cb-report-bug show <slug>     print a filed report
  cb-report-bug done <slug>     mark a report reviewed (drops a .reviewed sidecar); framework-dev
                                startup surfacing then hides it from the "unreviewed" count
EOF
    exit "${1:-1}"
}

# subcommands (list/show/done) — recognized only when they are the FIRST arg. Everything
# else keeps the historic `cb-report-bug "title" ... <<EOF ... EOF` filing pattern.
case "${1:-}" in
    list)
        shift
        [ -d "$DIR" ] || { echo "no framework-bug reports yet."; exit 0; }
        found=0
        for f in "$DIR"/*.md; do
            [ -f "$f" ] || continue
            found=1
            slug="$(basename "$f" .md)"
            mark="  "; [ -f "${f}.reviewed" ] && mark="✓ "
            title="$(sed -n '1s/^# //p' "$f" | head -1)"
            printf '%s%s\n      %s\n' "$mark" "$slug" "${title:-(no title)}"
        done
        [ "$found" = 0 ] && echo "no framework-bug reports yet." || {
            echo ""; echo "read one:  cb-report-bug show <slug>"
            echo "mark done: cb-report-bug done <slug>"
        }
        exit 0
        ;;
    show)
        slug="${2:-}"; [ -n "$slug" ] || usage
        f="$DIR/${slug}.md"
        [ -f "$f" ] || { echo "no such bug: $slug" >&2; exit 1; }
        echo "=== $slug ==="
        [ -f "${f}.reviewed" ] && echo "(reviewed on $(cat "${f}.reviewed" 2>/dev/null))"
        echo ""
        cat "$f"
        exit 0
        ;;
    done)
        slug="${2:-}"; [ -n "$slug" ] || usage
        f="$DIR/${slug}.md"
        [ -f "$f" ] || { echo "no such bug: $slug" >&2; exit 1; }
        date +%Y-%m-%dT%H-%M-%S > "${f}.reviewed" 2>/dev/null || echo reviewed > "${f}.reviewed"
        echo "cb-report-bug: marked $slug reviewed."
        exit 0
        ;;
    -h|--help) usage 0 ;;
esac

while [ $# -gt 0 ]; do
    case "$1" in
        --layer)     LAYER="${2:-other}"; shift ;;
        --body-file) BODY_FILE="${2:-}"; shift ;;
        -h|--help)   usage 0 ;;
        --)          shift; break ;;
        -*)          echo "cb-report-bug: unknown flag '$1'" >&2; usage ;;
        *)           if [ -z "$TITLE" ]; then TITLE="$1"; else TITLE="$TITLE $1"; fi ;;
    esac
    shift
done
[ -n "$TITLE" ] || usage

if [ -n "$BODY_FILE" ]; then
    BODY="$(cat "$BODY_FILE")"
elif [ ! -t 0 ]; then
    BODY="$(cat)"                      # piped / heredoc body
else
    BODY="_(no details provided — rerun with a body via stdin or --body-file)_"
fi

# Prefer the shared host-mounted drop dir; fall back to a per-project file if the
# mount isn't present (older host wrapper, or the mount failed).
APPEND=""
if ! mkdir -p "$DIR" 2>/dev/null || [ ! -w "$DIR" ]; then
    echo "cb-report-bug: shared report dir unavailable ($DIR); falling back to ./.dridock/FRAMEWORK-BUGS.md" >&2
    DIR="$(pwd)/.dridock"; mkdir -p "$DIR"
    OUT="$DIR/FRAMEWORK-BUGS.md"; APPEND=1
fi

TS="$(date +%Y-%m-%dT%H-%M-%S 2>/dev/null || echo unknown)"
SLUG="$(printf '%s' "$TITLE" | tr '[:upper:] ' '[:lower:]-' | tr -cd 'a-z0-9-' | cut -c1-40)"
[ -n "${OUT:-}" ] || OUT="$DIR/${PID}-${TS}-${SLUG}.md"

{
    [ -n "$APPEND" ] && echo "---"
    echo "# ${TITLE}"
    echo ""
    echo "- **layer:** ${LAYER}"
    echo "- **project id:** ${PID}"
    echo "- **filed:** ${TS}"
    echo "- **image variant:** ${CLAUDE_IMAGE_VARIANT:-unknown}"
    echo ""
    printf '%s\n' "$BODY"
    echo ""
} >> "$OUT"

echo "cb-report-bug: filed framework bug report -> $OUT"
