#!/usr/bin/env bash
# cb-browser — self-contained headless browser testing (Approach A1).
#
# Runs a headless Chromium (via the official Playwright image) as a SIBLING
# container on a shared project docker network, against a URL, and writes
# artifacts into your workspace. No host coupling: the browser and the workload
# both live in this project's colima VM. See docs/design/browser-testing.md.
#
# The official Playwright image ships the browsers but not the `playwright` npm
# module, so we `npm i` it at run time (the pinned version matches the image's
# pre-cached browsers, so no browser download happens — it's quick).
#
# Convention: start the web workloads you want to test on the shared network
# ($CB_BROWSER_NET, default "cb-net") so this reaches them by container name:
#     docker run -d --name api --network cb-net your/image
#     cb-browser shot http://api:8080            # -> ./cb-browser-out/{screenshot.png,page.json}
#     cb-browser script ./test.cjs               # run a Playwright script (require('playwright'))
#
# Env: CB_BROWSER_NET, CB_BROWSER_IMAGE, CB_BROWSER_PWVER, CB_BROWSER_OUT
set -euo pipefail

PW_VER="${CB_BROWSER_PWVER:-1.48.0}"
PW_IMAGE="${CB_BROWSER_IMAGE:-mcr.microsoft.com/playwright:v${PW_VER}-jammy}"
NET="${CB_BROWSER_NET:-cb-net}"
# browsers are cached in the image; only the JS package is fetched
INSTALL="npm i --no-save --prefix /pw playwright@${PW_VER} >/dev/null 2>&1"

# 'watch' (A2): a headful browser with a noVNC web UI you open from your Mac
WATCH_IMAGE="${CB_WATCH_IMAGE:-lscr.io/linuxserver/chromium:latest}"
WATCH_PORT="${CB_WATCH_PORT:-3010}"
WATCH_NAME="${CB_WATCH_NAME:-cb-watch}"

_usage() {
    cat >&2 <<EOF
usage:
  cb-browser shot <url> [out-dir]         navigate + full-page screenshot + page.json (title/text/console)
  cb-browser script <file.cjs> [args...]  run a Playwright script (require('playwright')). Your script is
                                          READ-ONLY at /work; write ALL artifacts to /out (= ./cb-browser-out,
                                          also \$CB_OUT). cwd is /out, so screenshot({path:'shot.png'}) just works.
  cb-browser watch <url> [port]           open a HEADFUL browser on <url> with a noVNC web UI you watch/drive
                                          from your Mac at http://<project-vm-ip>:<port> (default $WATCH_PORT)
  cb-browser watch-stop                   stop the watch browser
  cb-browser cdp <url> [out-dir]          drive the HUMAN's real Chrome (opt-in) to <url> via the CDP bridge
                                          — requires 'claudebox browser-bridge up' on the Mac first.
                                          <url> must be reachable FROM THE MAC (VM IP / localhost), NOT a
                                          cb-net container name — the Mac's Chrome can't resolve those.
                                          For cb-net / in-VM targets (incl. their websockets) use shot/script.
  cb-browser net                          ensure/print the shared network name

Put the workloads you test on the '$NET' network so they're reachable by name.
Artifacts default to ./cb-browser-out in the current workspace.
EOF
    exit "${1:-1}"
}

_ensure_net() { docker network inspect "$NET" >/dev/null 2>&1 || docker network create "$NET" >/dev/null; }

cmd="${1:-}"; shift || true
case "$cmd" in
  net)
    _ensure_net; echo "$NET" ;;

  shot)
    url="${1:-}"; [ -n "$url" ] || _usage
    outdir="${2:-${CB_BROWSER_OUT:-$PWD/cb-browser-out}}"; mkdir -p "$outdir"
    _ensure_net
    # The runner is passed via an env var and written INSIDE the container — a
    # mounted temp file wouldn't work (docker-out-of-docker: -v paths are resolved
    # by the VM daemon, which can't see the client's /tmp). The workspace-relative
    # out-dir IS visible to the VM (it's under the $PWD:$PWD mount).
    read -r -d '' runner <<'RUNNER' || true
const { chromium } = require("playwright");
(async () => {
  const browser = await chromium.launch();
  const page = await browser.newPage();
  const errs = [];
  page.on("console", m => { if (m.type() === "error") errs.push(m.text()); });
  const resp = await page.goto(process.env.TARGET, { waitUntil: "load", timeout: 20000 });
  await page.waitForTimeout(1000);
  await page.screenshot({ path: "/out/screenshot.png", fullPage: true });
  const info = {
    url: process.env.TARGET,
    status: resp && resp.status(),
    title: await page.title(),
    text: (await page.evaluate(() => document.body ? document.body.innerText : "")).slice(0, 2000),
    consoleErrors: errs,
  };
  require("fs").writeFileSync("/out/page.json", JSON.stringify(info, null, 2));
  console.log("cb-browser: status=" + info.status + " title=" + JSON.stringify(info.title) +
              (errs.length ? " consoleErrors=" + errs.length : ""));
  await browser.close();
})().catch(e => { console.error("cb-browser error:", e.message); process.exit(1); });
RUNNER
    docker run --rm --network "$NET" -e TARGET="$url" -e CBR_RUNNER="$runner" \
        -v "$outdir:/out" "$PW_IMAGE" \
        bash -lc "$INSTALL && printf '%s' \"\$CBR_RUNNER\" > /tmp/shot.cjs && NODE_PATH=/pw/node_modules node /tmp/shot.cjs"
    echo "cb-browser: artifacts -> $outdir/ (screenshot.png, page.json)" ;;

  script)
    script="${1:-}"; [ -f "$script" ] || _usage; shift
    sdir="$(cd "$(dirname "$script")" && pwd)"; sfile="$(basename "$script")"
    outdir="${CB_BROWSER_OUT:-$PWD/cb-browser-out}"; mkdir -p "$outdir"
    _ensure_net
    # /work is read-only (your script + its dir); /out is the ONE writable path and
    # maps to ./cb-browser-out in the workspace. cwd is /out so a naive
    # page.screenshot({path:'shot.png'}) lands there; CB_OUT=/out is the explicit
    # handle. The script still loads via its absolute /work path + NODE_PATH.
    docker run --rm --network "$NET" -e CB_OUT=/out -v "$sdir:/work:ro" -v "$outdir:/out" -w /out "$PW_IMAGE" \
        bash -lc "$INSTALL && NODE_PATH=/pw/node_modules node /work/$sfile $*"
    echo "cb-browser: /out -> $outdir/  (write artifacts to /out; /work is read-only)" ;;

  watch)
    url="${1:-}"; [ -n "$url" ] || _usage
    port="${2:-$WATCH_PORT}"
    _ensure_net
    docker rm -f "$WATCH_NAME" >/dev/null 2>&1 || true
    # headful Chromium with a noVNC web UI (published on the VM). On a project VM
    # (which has a reachable IP) this is browsable from the Mac at http://<vm-ip>:<port>.
    docker run -d --name "$WATCH_NAME" --network "$NET" -p "$port:3000" --shm-size=1g \
        -e CHROME_CLI="$url" "$WATCH_IMAGE" >/dev/null
    # wait for the noVNC web UI to actually come up (poll, don't fixed-sleep)
    printf 'cb-browser: starting watch browser'
    if docker run --rm --network "$NET" curlimages/curl:latest sh -c \
        'for i in $(seq 1 40); do curl -sf -o /dev/null --max-time 2 "http://'"$WATCH_NAME"':3000/" && exit 0; sleep 1; done; exit 1' >/dev/null 2>&1
    then echo " up."; else echo " (still starting — give it a few more seconds)"; fi
    # Two reachable paths: this project VM's DISTINCT reachable IP (col0, e.g.
    # 192.168.64.x from --network-address) is collision-free across projects and is
    # the one to prefer; colima ALSO forwards the published port to the Mac's
    # localhost, which is immediate but collides if two projects share a port.
    ip="${CLAUDEBOX_VM_IP:-$(ip -4 -o addr show 2>/dev/null | awk '{print $4}' | cut -d/ -f1 \
        | grep -E '^192\.168\.' | grep -vE '^192\.168\.5\.' | head -1)}" || true
    echo "cb-browser: watching $url (headful, live)"
    [ -n "${ip:-}" ] && echo "  open   http://$ip:$port        (this project's VM IP — no cross-project collision)"
    echo "  or     http://localhost:$port   (colima-forwarded; simplest, but collides if two projects share the port)"
    echo "  stop   cb-browser watch-stop" ;;

  watch-stop)
    docker rm -f "$WATCH_NAME" >/dev/null 2>&1 && echo "cb-browser: watch stopped" || echo "cb-browser: no watch running" ;;

  cdp)
    url="${1:-}"; [ -n "$url" ] || _usage
    [ -n "${CLAUDEBOX_HOST_CDP_URL:-}" ] || {
        echo "cb-browser: no host CDP bridge. On the Mac run 'claudebox browser-bridge up', then restart this session." >&2; exit 1; }
    outdir="${2:-${CB_BROWSER_OUT:-$PWD/cb-browser-out}}"; mkdir -p "$outdir"
    read -r -d '' runner <<'RUNNER' || true
const { chromium } = require("playwright");
(async () => {
  const b = await chromium.connectOverCDP(process.env.CDP_URL);
  const ctx = b.contexts()[0] || (await b.newContext());
  const page = await ctx.newPage();
  const resp = await page.goto(process.env.TARGET, { waitUntil: "load", timeout: 30000 });
  await page.waitForTimeout(500);
  try { await page.screenshot({ path: "/out/cdp.png" }); } catch (e) {}
  console.log("cb-browser cdp: drove your Chrome -> status=" + (resp && resp.status()) +
              " title=" + JSON.stringify(await page.title()));
  await b.close(); // disconnects; does NOT close your Chrome
})().catch(e => { console.error("cb-browser cdp error:", e.message); process.exit(1); });
RUNNER
    # --network host so the container reaches the Mac's bridge (192.168.64.1) via col0
    docker run --rm --network host -e TARGET="$url" -e CDP_URL="$CLAUDEBOX_HOST_CDP_URL" -e CBR_RUNNER="$runner" \
        -v "$outdir:/out" "$PW_IMAGE" \
        bash -lc "$INSTALL && printf '%s' \"\$CBR_RUNNER\" > /tmp/cdp.cjs && NODE_PATH=/pw/node_modules node /tmp/cdp.cjs"
    echo "cb-browser: opened $url in your Chrome (screenshot -> $outdir/cdp.png)" ;;

  ""|-h|--help) _usage 0 ;;
  *) echo "cb-browser: unknown command '$cmd'" >&2; _usage ;;
esac
